{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/*.{js,css}",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/server.ts"
    },
    {
      "source": "/feedback-widget.js",
      "destination": "/frontend/feedback-widget.js"
    },
    {
      "source": "/feedback-widget.css",
      "destination": "/frontend/feedback-widget.css"
    }
  ]
}
